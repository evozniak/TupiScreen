<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="320"
        x:Class="TupiScreen.MainWindow"
        Title="TupiScreen"
        MinWidth="380" MinHeight="240">
    <DockPanel LastChildFill="True">

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#1e1e2e" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Name="JoystickStatus" Foreground="#cdd6f4" VerticalAlignment="Center" />
                <TextBlock Name="CountdownText" Foreground="#f38ba8" FontWeight="Bold" VerticalAlignment="Center" />
                <Button Name="RevertButton" Content="Revert" IsVisible="False" />
            </StackPanel>
        </Border>

        <!-- With Joystick preset -->
        <Border BorderBrush="#313244" BorderThickness="1" CornerRadius="4" Margin="8" Padding="8">
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,2">
                    <TextBlock FontSize="14" FontWeight="SemiBold">🕹️ Controller preset</TextBlock>
                    <Button Name="RefreshButton" Content="↻" FontSize="12" Padding="6,2"
                            ToolTip.Tip="Reload displays and audio sinks" />
                </StackPanel>
                <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,4"
                           Text="These settings are applied automatically when a controller is connected and reverted when it is disconnected." />
                <StackPanel Name="JoyPanel" Spacing="2" />
                <TextBlock Text="Audio output:" Margin="0,8,0,2" Opacity="0.7" FontSize="12" />
                <ComboBox Name="JoyAudioCombo" HorizontalAlignment="Stretch" />
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                    <Button Name="TestJoyButton" Content="Preview (15 s)"
                            ToolTip.Tip="Temporarily apply the preset for 15 seconds, then revert automatically" />
                </StackPanel>
            </StackPanel>
        </Border>

    </DockPanel>
</Window>
